{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://farm-automation.local/schemas/agent_proposal.schema.json",
  "title": "Agent Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "agent_name",
    "agent_model",
    "proposal_type",
    "input_snapshot_hash",
    "recommendation",
    "confidence",
    "risk_level",
    "requires_human_review",
    "created_at"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "pattern": "^APRP_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "agent_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "agent_model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "proposal_type": {
      "type": "string",
      "enum": [
        "TASK_CLASSIFICATION",
        "TASK_ASSIGNMENT",
        "PROJECT_STATUS",
        "RESTOCK",
        "EXECUTION_ACTION",
        "RISK_ASSESSMENT",
        "OTHER"
      ]
    },
    "subject_type": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 50
    },
    "subject_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 80
    },
    "input_snapshot_hash": {
      "$ref": "common.schema.json#/$defs/content_hash"
    },
    "recommendation": {
      "type": "object"
    },
    "rationale_summary": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 5000
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_level": {
      "$ref": "common.schema.json#/$defs/risk_level"
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "rules_triggered": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      },
      "uniqueItems": true
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    }
  }
}
