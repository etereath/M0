{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://farm-automation.local/schemas/approval.schema.json",
  "title": "Approval Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_request_id",
    "approval_type",
    "subject_type",
    "subject_id",
    "payload_hash",
    "status",
    "requested_by",
    "requested_at"
  ],
  "properties": {
    "approval_request_id": {
      "type": "string",
      "pattern": "^APRV_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "approval_type": {
      "type": "string",
      "enum": [
        "CONTROLLED_TASK",
        "CHANGE_DUE_AT",
        "PROJECT_COMPLETE",
        "PROJECT_CANCEL",
        "INVENTORY_ADJUSTMENT",
        "EXECUTION_SIDE_EFFECT",
        "OTHER"
      ]
    },
    "subject_type": {
      "type": "string",
      "maxLength": 50
    },
    "subject_id": {
      "type": "string",
      "maxLength": 80
    },
    "payload_hash": {
      "$ref": "common.schema.json#/$defs/content_hash"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "APPROVED",
        "REJECTED",
        "CANCELLED",
        "EXPIRED"
      ]
    },
    "requested_by": {
      "$ref": "common.schema.json#/$defs/actor"
    },
    "requested_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "expires_at": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolved_by_employee_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^EMP_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "resolved_at": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolution_note": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2000
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "APPROVED",
              "REJECTED",
              "CANCELLED"
            ]
          }
        }
      },
      "then": {
        "required": [
          "resolved_by_employee_id",
          "resolved_at"
        ],
        "properties": {
          "resolved_by_employee_id": {
            "type": "string",
            "pattern": "^EMP_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "resolved_at": {
            "$ref": "common.schema.json#/$defs/timestamp"
          }
        }
      }
    }
  ]
}
