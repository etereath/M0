{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://farm-automation.local/schemas/project_create.schema.json",
  "title": "Project Create Request",
  "description": "Client-supplied fields for creating a project. Identity, version, status, timestamps, and content hash are server-generated.",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "owner_employee_id"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200
    },
    "objective": {
      "type": ["string", "null"],
      "maxLength": 5000
    },
    "scope": {
      "type": ["string", "null"],
      "maxLength": 5000
    },
    "owner_employee_id": {
      "type": "string",
      "pattern": "^EMP_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "priority": {
      "$ref": "common.schema.json#/$defs/project_priority",
      "default": "NORMAL"
    },
    "planned_start_date": {
      "anyOf": [
        {"$ref": "common.schema.json#/$defs/date"},
        {"type": "null"}
      ]
    },
    "target_date": {
      "anyOf": [
        {"$ref": "common.schema.json#/$defs/date"},
        {"type": "null"}
      ]
    }
  }
}
