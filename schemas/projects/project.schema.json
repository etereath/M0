{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://farm-automation.local/schemas/project.schema.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "version",
    "title",
    "owner_employee_id",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^PROJ_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/version"
    },
    "title": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200
    },
    "objective": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 5000
    },
    "scope": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 5000
    },
    "owner_employee_id": {
      "type": "string",
      "pattern": "^EMP_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": {
      "$ref": "common.schema.json#/$defs/project_status"
    },
    "priority": {
      "$ref": "common.schema.json#/$defs/project_priority",
      "default": "NORMAL"
    },
    "planned_start_date": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/date"
        },
        {
          "type": "null"
        }
      ]
    },
    "target_date": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/date"
        },
        {
          "type": "null"
        }
      ]
    },
    "progress_percent_confirmed": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 0
    },
    "progress_percent_suggested": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "current_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      }
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "updated_at": {
      "$ref": "common.schema.json#/$defs/timestamp"
    },
    "completed_at": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "cancelled_at": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "content_hash": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/content_hash"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "COMPLETED"
          }
        }
      },
      "then": {
        "required": [
          "completed_at"
        ],
        "properties": {
          "completed_at": {
            "$ref": "common.schema.json#/$defs/timestamp"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "CANCELLED"
          }
        }
      },
      "then": {
        "required": [
          "cancelled_at"
        ],
        "properties": {
          "cancelled_at": {
            "$ref": "common.schema.json#/$defs/timestamp"
          }
        }
      }
    }
  ]
}
